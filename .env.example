# 🎩 Lucien Bot - Configuración de Entorno
# Copiar este archivo a .env y completar los valores

# ==================== OBLIGATORIAS ====================

# Token del Bot de Telegram (obtener de @BotFather)
BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrSTUvwxyz

# IDs de administradores separados por comas
# Obtener tu ID desde @userinfobot
ADMIN_IDS=123456789,987654321

# ==================== BASE DE DATOS ====================

# Opción 1: SQLite (desarrollo/local)
DATABASE_URL=sqlite:///lucien_bot.db

# Opción 2: PostgreSQL (producción/Railway)
# Railway genera esta variable automáticamente
# DATABASE_URL=postgresql://user:password@host:port/database

# ==================== CONFIGURACIÓN ====================

# Zona horaria (por defecto: America/Mexico_City)
TIMEZONE=America/Mexico_City

# Username de la creadora de contenido (sin @)
# Usado para botón de contacto en promociones
CREATOR_USERNAME=dianita

# ==================== CANALES ====================

# Canal VIP (ID numérico o @username)
VIP_CHANNEL_ID=@divan_de_diana

# Canal gratuito (ID numérico o @username)
FREE_CHANNEL_ID=@senorita_kinky_free

# ==================== OPCIONALES ====================

# Nivel de logging (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Modo debug (True/False)
DEBUG=False

# ==================== SEGURIDAD ====================

# Clave secreta para encriptación (generar con: openssl rand -hex 32)
# SECRET_KEY=tu_clave_secreta_aqui

# ==================== INTEGRACIONES (FUTURO) ====================

# Webhook URL (si se usa webhook en lugar de polling)
# WEBHOOK_URL=https://tu-dominio.com/webhook

# Puerto para webhook (Railway asigna automáticamente)
# PORT=8000
